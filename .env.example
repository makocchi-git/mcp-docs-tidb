# TiDB connection
TIDB_HOST=127.0.0.1
TIDB_PORT=4000
TIDB_USER=root
TIDB_PASSWORD=
TIDB_DATABASE=test
# Set to 1 when connecting to TiDB Serverless or a cluster that requires TLS.
TIDB_SSL_VERIFY_CERT=0
# Optional path to a CA bundle (e.g. /etc/ssl/cert.pem on macOS).
# TIDB_SSL_CA=/etc/ssl/cert.pem

# Default collection (table) used when the MCP tool argument is omitted.
COLLECTION_NAME=kb

# Embeddings
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Behavior
TIDB_SEARCH_LIMIT=10
TIDB_READ_ONLY=0
# Set to 1 to create an HNSW vector index alongside auto-created tables.
# Requires TiDB v8.4+ and a TiFlash replica in the cluster.
TIDB_USE_VECTOR_INDEX=1

# Connection timeouts (seconds). Increase for slow or remote TiDB instances.
# TIDB_CONNECT_TIMEOUT=10
# TIDB_READ_TIMEOUT=30

# Security: restrict the docs-tidb-ingest tool to paths under a root directory.
# Prevents path-traversal attacks when the MCP server is reachable by untrusted clients.
# TIDB_INGEST_ROOT=/data/docs

# Limit the number of paths accepted in a single docs-tidb-ingest call.
# TIDB_INGEST_MAX_PATHS=1000
